@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-end align-items-center gap-2">
            <AuthorizeView>
                <Authorized>
                    <span class="me-3 text-muted">
                        Signed in as <strong>@context.User.Identity?.Name</strong>
                    </span>
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="/Account/Login" />
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Log out</button>
                    </form>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
