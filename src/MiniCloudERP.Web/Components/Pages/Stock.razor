@page "/stock"
@rendermode InteractiveServer
@using MiniCloudERP.Business.Common
@using MiniCloudERP.Business.Products
@using MiniCloudERP.Business.Stock
@using MiniCloudERP.Entities.Enums
@using MiniCloudERP.Entities.Models
@inject IStockService StockService
@inject IProductService ProductService

<PageTitle>Stock</PageTitle>

<h1>Stock Management</h1>

<div class="row g-4 mb-4">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Increase Stock</h5>
                <div class="mb-3">
                    <label class="form-label">Product</label>
                    <select class="form-select" @bind="increaseProductId">
                        <option value="0">Select product...</option>
                        @if (products is not null)
                        {
                            @foreach (var product in products)
                            {
                                <option value="@product.Id">@product.Name (@product.Sku) — Current: @product.CurrentStock</option>
                            }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Quantity</label>
                    <input class="form-control" type="number" min="1" @bind="increaseQuantity" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Notes</label>
                    <input class="form-control" @bind="increaseNotes" />
                </div>
                <button class="btn btn-success" @onclick="IncreaseStockAsync">Increase Stock</button>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Decrease Stock</h5>
                <div class="mb-3">
                    <label class="form-label">Product</label>
                    <select class="form-select" @bind="decreaseProductId">
                        <option value="0">Select product...</option>
                        @if (products is not null)
                        {
                            @foreach (var product in products)
                            {
                                <option value="@product.Id">@product.Name (@product.Sku) — Current: @product.CurrentStock</option>
                            }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Quantity</label>
                    <input class="form-control" type="number" min="1" @bind="decreaseQuantity" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Notes</label>
                    <input class="form-control" @bind="decreaseNotes" />
                </div>
                <button class="btn btn-warning" @onclick="DecreaseStockAsync">Decrease Stock</button>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Adjust Stock</h5>
                <div class="mb-3">
                    <label class="form-label">Product</label>
                    <select class="form-select" @bind="adjustProductId">
                        <option value="0">Select product...</option>
                        @if (products is not null)
                        {
                            @foreach (var product in products)
                            {
                                <option value="@product.Id">@product.Name (@product.Sku) — Current: @product.CurrentStock</option>
                            }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">New Quantity</label>
                    <input class="form-control" type="number" min="0" @bind="adjustNewQuantity" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Notes</label>
                    <input class="form-control" @bind="adjustNotes" />
                </div>
                <button class="btn btn-primary" @onclick="AdjustStockAsync">Adjust Stock</button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-success">@message</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="card">
    <div class="card-body">
        <h5 class="card-title">Stock Movement History</h5>

        @if (history is null)
        {
            <p>Loading...</p>
        }
        else if (history.Count == 0)
        {
            <div class="alert alert-info">No stock movements recorded yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Product</th>
                            <th>Type</th>
                            <th class="text-end">Quantity</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in history)
                        {
                            <tr>
                                <td>@entry.TransactionDateUtc.ToLocalTime().ToString("g")</td>
                                <td>@entry.Product?.Name</td>
                                <td><span class="badge @GetTypeBadgeClass(entry.TransactionType)">@entry.TransactionType</span></td>
                                <td class="text-end">@entry.Quantity</td>
                                <td>@entry.Notes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<Product>? products;
    private List<StockTransaction>? history;

    private int increaseProductId;
    private int increaseQuantity = 1;
    private string? increaseNotes;

    private int decreaseProductId;
    private int decreaseQuantity = 1;
    private string? decreaseNotes;

    private int adjustProductId;
    private int adjustNewQuantity;
    private string? adjustNotes;

    private string? message;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        products = await ProductService.GetAllAsync();
        history = await StockService.GetHistoryAsync();
    }

    private async Task IncreaseStockAsync()
    {
        errorMessage = null;

        if (increaseProductId <= 0 || increaseQuantity <= 0)
        {
            errorMessage = "Select a product and enter a valid quantity.";
            return;
        }

        try
        {
            await StockService.IncreaseStockAsync(increaseProductId, increaseQuantity, increaseNotes);
            await ReloadAsync();
            message = "Stock increased successfully.";
            increaseProductId = 0;
            increaseQuantity = 1;
            increaseNotes = null;
        }
        catch (BusinessValidationException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception)
        {
            errorMessage = "Could not increase stock.";
        }
    }

    private async Task DecreaseStockAsync()
    {
        errorMessage = null;

        if (decreaseProductId <= 0 || decreaseQuantity <= 0)
        {
            errorMessage = "Select a product and enter a valid quantity.";
            return;
        }

        try
        {
            await StockService.DecreaseStockAsync(decreaseProductId, decreaseQuantity, decreaseNotes);
            await ReloadAsync();
            message = "Stock decreased successfully.";
            decreaseProductId = 0;
            decreaseQuantity = 1;
            decreaseNotes = null;
        }
        catch (BusinessValidationException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception)
        {
            errorMessage = "Could not decrease stock.";
        }
    }

    private async Task AdjustStockAsync()
    {
        errorMessage = null;

        if (adjustProductId <= 0)
        {
            errorMessage = "Select a product.";
            return;
        }

        try
        {
            await StockService.AdjustStockAsync(adjustProductId, adjustNewQuantity, adjustNotes);
            await ReloadAsync();
            message = "Stock adjusted successfully.";
            adjustProductId = 0;
            adjustNewQuantity = 0;
            adjustNotes = null;
        }
        catch (BusinessValidationException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception)
        {
            errorMessage = "Could not adjust stock.";
        }
    }

    private static string GetTypeBadgeClass(StockTransactionType type) => type switch
    {
        StockTransactionType.StockIn => "text-bg-success",
        StockTransactionType.StockOut => "text-bg-warning",
        StockTransactionType.Adjustment => "text-bg-info",
        _ => "text-bg-secondary"
    };
}
